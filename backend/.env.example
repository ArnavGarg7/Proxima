ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/proxima
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth — Required for login
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/api/auth/callback
# Authorized JavaScript origin: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Security
# Generate with: openssl rand -hex 32
SESSION_SECRET=your_random_session_secret_here
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Generate key pair with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# AI Providers
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS S3 Storage (optional — uses local storage if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=proxima-uploads
AWS_REGION=us-east-1

# Budget Controls
MONTHLY_AI_BUDGET_USD=50.00
COST_ALERT_THRESHOLD=0.80

# Monitoring
SENTRY_DSN=

# Celery
FLOWER_PASSWORD=change_me_in_production
